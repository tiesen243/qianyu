{
  "name": "@qianyu/ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/utils.d.mts",
      "default": "./dist/utils.mjs"
    },
    "./*": {
      "types": "./dist/components/*.d.mts",
      "default": "./dist/components/*.mjs"
    },
    "./tailwind.css": "./dist/tailwind.css"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "git clean -fdX .cache dist node_modules",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "react": "catalog:react",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@qianyu/tsconfig": "workspace:*",
    "@types/react": "catalog:react",
    "tailwindcss": "catalog:tailwind",
    "tsdown": "^0.21.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "catalog:dev"
  }
}
