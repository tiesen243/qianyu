{
  "name": "@qianyu/lib",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./*": {
      "types": "./dist/*.d.mts",
      "default": "./dist/*.mjs"
    },
    "./api/*": {
      "types": "./dist/api/*.d.mts",
      "default": "./dist/api/*.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "git clean -fdX .cache dist node_modules",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "catalog:prod"
  },
  "devDependencies": {
    "@qianyu/tsconfig": "workspace:*",
    "@types/node": "catalog:dev",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev"
  }
}
