{
  "name": "@qianyu/api",
  "version": "0.2.2",
  "private": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./*": {
      "types": "./dist/*.d.mts",
      "default": "./dist/*.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "git clean -fdX .cache dist node_modules",
    "dev": "bun --bun --hot src/server.ts",
    "start": "bun --bun dist/server.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:dev",
    "@qianyu/infra": "workspace:*",
    "@qianyu/tsconfig": "workspace:*",
    "@types/bun": "^1.3.12",
    "drizzle-kit": "^0.31.10",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev"
  }
}
