{
  "name": "@qianyu/api",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/server.d.mts",
      "default": "./dist/server.mjs"
    },
    "./models/*": {
      "types": "./dist/models/*.model.d.mts",
      "default": "./dist/models/*.model.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "git clean -fdX .cache dist node_modules",
    "dev": "bun --bun --hot src/server.ts",
    "start": "bun --bun dist/server.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.0",
    "elysia": "^1.4.28"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:dev",
    "@qianyu/infra": "workspace:*",
    "@qianyu/tsconfig": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "drizzle-kit": "^0.31.10",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev"
  }
}
