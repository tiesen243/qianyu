{
  "name": "@qianyu/api",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/server.d.mts",
      "default": "./dist/server.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "git clean -fdX .cache .react-router dist node_modules",
