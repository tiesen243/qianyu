{
  "extends": "@qianyu/tsconfig/react-package.json",
  "compilerOptions": {
    "types": ["node", "vite/client", "@cloudflare/workers-types"],
    "rootDirs": [".", "./.react-router/types"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "workers/*.ts",
    ".react-router/types/**/*"
  ],
  "exclude": ["build", "node_modules"]
}
