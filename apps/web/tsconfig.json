{
  "extends": "@qianyu/tsconfig/react-package.json",
  "compilerOptions": {
    "types": ["node", "vite/client"],
    "rootDirs": [".", "./.react-router/types"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", ".react-router/types/**/*"],
  "exclude": ["build", "node_modules"]
}
